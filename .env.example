# URL aplikasi anda. Callback ToyyibPay tidak berfungsi pada localhost.
APP_BASE_URL=http://localhost:3000

# Port server tempatan.
PORT=3000

# URL ToyyibPay. Guna https://dev.toyyibpay.com untuk sandbox.
TOYYIBPAY_BASE_URL=https://toyyibpay.com

# Lengkapkan dua nilai ini sebelum menjana bil sebenar.
TOYYIBPAY_USER_SECRET_KEY=your-user-secret-key
TOYYIBPAY_CATEGORY_CODE=your-category-code
